# Локальный запуск без Docker
DATABASE_URL=postgresql://postgres:1234@127.0.0.1:5432/StudentCabinet

# Администратор (создаётся init_db.py; пароль синхронизируется при повторном init_db)
ADMIN_EMAIL=admin@vyatsu.ru
ADMIN_PASSWORD=admin123

# Секрет сессий Flask — обязательно свой длинный ключ в production
FLASK_SECRET_KEY=change-me-in-production
# Альias (если задан только SECRET_KEY — тоже подхватится)
# SECRET_KEY=

# HTTPS на сервере: SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SECURE=0

# Ограничение попыток входа (по IP)
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_WINDOW_SECONDS=300
# LOGIN_LOCKOUT_SECONDS=900

# VK: новости и расписание из сообщества
VK_ACCESS_TOKEN=

# Яндекс.Карты
YANDEX_MAPS_API_KEY=
YANDEX_GEOCODER_API_KEY=
